 arch/mips/dts/mt7628an-tplink-tl-mr6400-v5.dts | 72 ++++++++++++++++++
 arch/mips/mach-mtmips/mt7628/Kconfig         | 10 +++
 board/tplink/tl-mr6400-v5/Kconfig            | 12 +++
 board/tplink/tl-mr6400-v5/Makefile           |  3 +
 board/tplink/tl-mr6400-v5/board.c            | 14 ++++
 configs/mt7628_tplink_tl-mr6400-v5_defconfig | 77 ++++++++++++++++++++
 include/configs/tplink-tl-mr6400-v5.h        | 22 +++++
 8 files changed, 211 insertions(+)
 create mode 100644 arch/mips/dts/mt7628an-tplink-tl-mr6400-v5.dts
 create mode 100644 board/tplink/tl-mr6400-v5/Kconfig
 create mode 100644 board/tplink/tl-mr6400-v5/Makefile
 create mode 100644 board/tplink/tl-mr6400-v5/board.c
 create mode 100644 configs/mt7628_tplink_tl-mr6400-v5_defconfig
 create mode 100644 include/configs/tplink-tl-mr6400-v5.h

--- a/arch/mips/dts/Makefile
+++ b/arch/mips/dts/Makefile
@@ -25,6 +25,7 @@ dtb-$(CONFIG_TARGET_OCTEON_EBB7304) += m
 dtb-$(CONFIG_BOARD_NETGEAR_CG3100D) += netgear,cg3100d.dtb
 dtb-$(CONFIG_BOARD_NETGEAR_DGND3700V2) += netgear,dgnd3700v2.dtb
 dtb-$(CONFIG_BOARD_RAVPOWER_RP_WD009) += ravpower-rp-wd009.dtb
+dtb-$(CONFIG_BOARD_TPLINK_TL_MR6400_V5) += mt7628an-tplink-tl-mr6400-v5.dtb
 dtb-$(CONFIG_BOARD_SAGEM_FAST1704) += sagem,f@st1704.dtb
 dtb-$(CONFIG_BOARD_SFR_NB4_SER) += sfr,nb4-ser.dtb
 dtb-$(CONFIG_BOARD_TPLINK_WDR4300) += tplink_wdr4300.dtb

--- /dev/null
+++ b/arch/mips/dts/mt7628an-tplink-tl-mr6400-v5.dts
@@ -0,0 +1,72 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * TP-Link TL-MR6400 v5 (MT7628AN, 64 MiB DDR2, 8 MiB SPI-NOR)
+ */
+
+/dts-v1/;
+
+#include "mt7628a.dtsi"
+
+/ {
+	compatible = "tplink,tl-mr6400-v5", "ralink,mt7628a-soc";
+	model = "TP-Link TL-MR6400 v5";
+
+	aliases {
+		serial0 = &uart0;
+		spi0 = &spi0;
+	};
+
+	memory@0 {
+		device_type = "memory";
+		reg = <0x0 0x4000000>;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&spi0 {
+	status = "okay";
+	num-cs = <2>;
+
+	spi-flash@0 {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		compatible = "jedec,spi-nor";
+		spi-max-frequency = <25000000>;
+		reg = <0>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "bootloader";
+				reg = <0x000000 0x040000>;
+				read-only;
+			};
+
+			partition@40000 {
+				label = "firmware";
+				reg = <0x040000 0x7bf000>;
+			};
+
+			partition@7ff000 {
+				label = "factory";
+				reg = <0x7ff000 0x001000>;
+				read-only;
+			};
+		};
+	};
+};
+
+&eth {
+	pinctrl-names = "default";
+	pinctrl-0 = <&ephy_router_mode>;
+};

--- a/arch/mips/mach-mtmips/mt7628/Kconfig
+++ b/arch/mips/mach-mtmips/mt7628/Kconfig
@@ -40,6 +40,15 @@ config BOARD_RAVPOWER_RP_WD009
 	help
 	  RAVPower RP-WD009
 
+config BOARD_TPLINK_TL_MR6400_V5
+	bool "TP-Link TL-MR6400 v5"
+	depends on SOC_MT7628
+	select BOARD_LATE_INIT
+	select SPL_SERIAL
+	help
+	  TP-Link TL-MR6400 v5 LTE router. MT7628AN SoC, 64 MiB DDR2,
+	  8 MiB SPI-NOR flash. SPL boots from NOR.
+
 config BOARD_VOCORE2
 	bool "VoCore2"
 	select SPL_SERIAL
@@ -70,4 +79,5 @@ config SYS_CONFIG_NAME
 source "board/gardena/smart-gateway-mt7688/Kconfig"
 source "board/ravpower/rp-wd009/Kconfig"
 source "board/seeed/linkit-smart-7688/Kconfig"
+source "board/tplink/tl-mr6400-v5/Kconfig"
 source "board/vocore/vocore2/Kconfig"

